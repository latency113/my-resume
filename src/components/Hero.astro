---

---

<section
	class="opacity-0 animate-fade-up [animation-delay:100ms] pb-12 mb-12 border-b border-black/10"
>
	<div
		class="flex flex-col-reverse md:flex-row items-center justify-between gap-12 md:gap-8"
	>
		<div class="flex-1 text-center md:text-left">
			<h1
				class="text-5xl md:text-6xl font-extrabold mb-2 tracking-tight leading-tight truncate"
			>
				สวัสดีครับ ผม <span class="text-gradient">ขัน สามนวล</span>
			</h1>
			<h2
				class="text-2xl font-medium flex justify-center md:justify-start text-slate-500 mt-0 pb-0 mb-6 after:hidden"
			>
				วิศวกรซอฟต์แวร์
			</h2>
			<p
				class="text-lg text-slate-600 max-w-xl leading-relaxed my-6 mx-auto md:mx-0"
			>
				วิศวกรซอฟต์แวร์ผู้มีความมุ่งมั่น พร้อมประสบการณ์กว่า 5 ปี
				ในการพัฒนาและออกแบบเว็บแอปพลิเคชันที่รองรับการขยายตัว
				มีความเชี่ยวชาญใน JavaScript, React และ Node.js
				กระตือรือร้นในการเรียนรู้เทคโนโลยีใหม่ๆ
				และแก้ปัญหาที่ซับซ้อนอยู่เสมอ
			</p>
			<div
				class="flex gap-4 mt-8 flex-wrap justify-center md:justify-start"
			>
				<a href="mailto:hello@example.com" class="btn-primary">
					<svg
						width="20"
						height="20"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
						><path
							d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"
						></path><polyline points="22,6 12,13 2,6"
						></polyline></svg
					>
					ส่งอีเมล
				</a>
				<a
					href="https://github.com/johndoe"
					target="_blank"
					class="btn-outline"
				>
					<svg
						width="20"
						height="20"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
						><path
							d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"
						></path></svg
					>
					GitHub
				</a>
				<a
					href="https://linkedin.com/in/johndoe"
					target="_blank"
					class="btn-outline"
				>
					<svg
						width="20"
						height="20"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
						><path
							d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"
						></path><rect x="2" y="9" width="4" height="12"
						></rect><circle cx="4" cy="4" r="2"></circle></svg
					>
					LinkedIn
				</a>
			</div>
		</div>

		<!-- Profile Image Section -->
		<div
			class="relative w-48 h-48 md:w-64 md:h-64 shrink-0 mx-auto md:mx-0"
		>
			<!-- Glowing Aura Background -->
			<div
				class="absolute inset-0 bg-gradient-to-br from-sky-400 to-violet-500 rounded-full blur-2xl opacity-40 animate-pulse"
			>
			</div>
			<!-- Image Container -->
			<div
				class="absolute inset-0 rounded-full border-4 border-white/60 shadow-xl overflow-hidden bg-slate-100 flex items-center justify-center group cursor-pointer transition-transform duration-300 hover:scale-105"
			>
				<img
					src="public/IMG_0161.JPG"
					alt="คุณขัน สามนวล"
					class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
					onerror="this.style.display='none'; this.nextElementSibling.style.display='block';"
				/>
				<!-- Fallback Icon if image not found -->
				<svg
					class="w-20 h-20 text-slate-300 hidden"
					xmlns="http://www.w3.org/2000/svg"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="1.5"
					stroke-linecap="round"
					stroke-linejoin="round"
					><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"
					></path><circle cx="12" cy="7" r="4"></circle></svg
				>
			</div>
		</div>
	</div>
</section>
